# ── Database ─────────────────────────────────
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/sesmag_hr
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sesmag_hr
DB_USER=postgres
DB_PASSWORD=yourpassword

# ── Auth ─────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret_string
JWT_EXPIRES_IN=24h

# ── Server ────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Logging ──────────────────────────────────
LOG_LEVEL=info
